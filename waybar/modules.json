{
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "format-icons": {
            "urgent": "",
            "active": "",
            "default": ""
        }
    },
    
    "hyprland/window": {
        "format": "{title}"
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon} {volume}%  {format_source}",
        "format-bluetooth-muted": " {icon} {format_source}",
        "format-muted": " {format_source}",
        "format-source": " {volume}%",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pkill -HUP -f waybar_peek && setsid pavucontrol >/dev/null 2>&1 &"
    },

    "cpu": {
        "format": "  {usage}%",
        "tooltip": true
    },

    "custom/librewolf": {
        "format": "", 
        "tooltip": "Open Librewolf",
        "on-click": "setsid librewolf >/dev/null 2>&1 &",
        "max-length": 3
    },
        "custom/nemo": {
        "format": "", 
        "tooltip": "Open file manager",
        "on-click": "setsid nemo >/dev/null 2>&1 &",
        "max-length": 3
    },

        "custom/obsidian": {
        "format": "🔮",
        "tooltip": "Open L",
        "on-click": "setsid /home/tiled/dirc/Obsidian-1.11.7.AppImage >/dev/null 2>&1 &",
        "max-length": 2
    },
    "custom/term": {
        "format": "", 
        "tooltip": "Open kitty",
        "on-click": "setsid kitty >/dev/null 2>&1 &",
        "max-length": 3
    },
"custom/pycharm": {
    "format": "",
    "tooltip": "PyCharm",
    "on-click": "setsid /home/tiled/pycharm-2025.3.2/bin/pycharm %f >/dev/null 2>&1 &",
    "max-length": 3
},

"custom/idea": {
    "format": "",
    "tooltip": "IntelliJ IDEA",
    "on-click": "setsid /home/tiled/idea-IU-253.30387.90/bin/idea %f >/dev/null 2>&1 &",
    "max-length": 3
},

"custom/clion": {
    "format": "",
    "tooltip": "CLion",
    "on-click": "setsid /home/tiled/clion-2025.3.2/bin/clion %f >/dev/null 2>&1 &",
    "max-length": 3
},
"custom/pen_tablet": {
    "format": "",
    "tooltip": "XP-Pen",
    "on-click": "setsid /usr/lib/pentablet/PenTablet.sh >/dev/null 2>&1 &"
},

    "temperature": {
        "interval": 10,
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
        "critical-threshold": 100,
        "format-critical": " {temperatureC}",
        "format": " {temperatureC}°C"
    },


    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "  {capacity}%",
        "format-plugged": "  {capacity}%",
        "format-alt": "{time}  {icon}",
        "format-icons": ["", "", "", "", ""]
    }
}
